{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openai/gpt-5.1-codex-mini",
  "default_agent": "build",
  "compaction": {
    "auto": false,
    "prune": false
  },
  "keybinds": {
    "input_submit": "enter",
    "input_newline": "ctrl+enter"
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git checkout *": "ask",
      "rm -rf *": "ask"
    },
    "external_directory": "ask"
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "share": "disabled"
}
